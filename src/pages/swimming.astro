---
// src/pages/swimming.astro
// 1. 引入全局 Tailwind 样式 (这是样式生效的关键！)
import '../styles/global.css';
---
<!doctype html>
<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>我的游泳生活 | Sun & Water</title>
    
    <!-- 引入活泼圆润的字体 -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700&family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    
    <style is:global>
      body { font-family: 'Nunito', sans-serif; }
      
      /* 水波浮动动画 */
      @keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-15px); }
      }
      .animate-float { animation: float 4s ease-in-out infinite; }
      .animate-float-delayed { animation: float 5s ease-in-out infinite 1s; }

      /* 阳光闪烁动画 */
      @keyframes shimmer {
        0% { opacity: 0.3; transform: scale(0.8); }
        50% { opacity: 0.6; transform: scale(1.2); }
        100% { opacity: 0.3; transform: scale(0.8); }
      }
      .sun-glow { animation: shimmer 3s infinite; }
    </style>
  </head>
  
  <!-- 背景：明亮的蓝天到浅海的渐变 -->
  <body class="bg-gradient-to-br from-sky-300 via-cyan-200 to-blue-100 text-slate-800 min-h-screen relative overflow-x-hidden selection:bg-orange-400 selection:text-white">
    
    <!-- 装饰：太阳 -->
    <div class="absolute top-10 right-10 md:top-20 md:right-20 w-24 h-24 md:w-32 md:h-32 bg-yellow-400 rounded-full blur-xl opacity-60 sun-glow pointer-events-none"></div>
    <div class="absolute top-12 right-12 md:top-24 md:right-24 w-20 h-20 md:w-28 md:h-28 bg-orange-300 rounded-full blur-md opacity-80 pointer-events-none"></div>

    <!-- 装饰：漂浮的气泡/水珠 -->
    <div class="absolute top-1/4 left-10 w-16 h-16 bg-white/40 rounded-full blur-xl animate-float pointer-events-none"></div>
    <div class="absolute bottom-1/3 right-20 w-24 h-24 bg-cyan-300/30 rounded-full blur-2xl animate-float-delayed pointer-events-none"></div>

    <!-- 导航栏：白色玻璃感 -->
    <header class="fixed w-full top-0 z-50 transition-all duration-300">
      <div class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center">
        <!-- 返回主页链接 (关键切换点) -->
        <a href="/" class="group flex items-center gap-2 px-4 py-2 bg-white/60 backdrop-blur-md rounded-full shadow-sm hover:bg-white hover:shadow-md transition-all">
          <svg class="w-5 h-5 text-slate-600 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          <span class="text-sm font-bold text-slate-700">返回开发主页</span>
        </a>

        <nav class="hidden md:flex space-x-2 bg-white/40 backdrop-blur-md p-1.5 rounded-full shadow-sm border border-white/50">
          <a href="#philosophy" class="px-4 py-2 rounded-full text-sm font-bold text-slate-700 hover:bg-white hover:text-orange-500 transition-all">游泳哲学</a>
          <a href="#gallery" class="px-4 py-2 rounded-full text-sm font-bold text-slate-700 hover:bg-white hover:text-orange-500 transition-all">精彩瞬间</a>
          <a href="#gear" class="px-4 py-2 rounded-full text-sm font-bold text-slate-700 hover:bg-white hover:text-orange-500 transition-all">装备库</a>
        </nav>
        
        <div class="md:hidden text-2xl">🏊‍♂️</div>
      </div>
    </header>

    <main class="relative z-10 pt-32 pb-20 px-6">
      <div class="max-w-4xl mx-auto space-y-24">

        <!-- 1. Hero Section: 充满活力 -->
        <section class="text-center space-y-8 py-10">
          <div class="inline-block px-4 py-1.5 rounded-full bg-orange-400 text-white font-bold text-sm shadow-lg shadow-orange-400/30 animate-bounce">
            🌞 阳光 · 汗水 · 自由
          </div>
          
          <h1 class="text-5xl md:text-7xl font-black text-slate-800 leading-tight">
            在水里，<br />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-cyan-500">我找到了节奏</span>
          </h1>
          
          <p class="text-xl md:text-2xl text-slate-600 max-w-2xl mx-auto font-medium">
            写代码是逻辑的构建，游泳是身心的释放。<br>
            这里记录我的训练日常、比赛瞬间和对水的热爱。
          </p>

          <div class="flex justify-center gap-4 pt-4">
            <a href="#gallery" class="px-8 py-4 bg-blue-600 text-white rounded-full font-bold shadow-xl shadow-blue-600/30 hover:bg-blue-500 hover:scale-105 hover:-translate-y-1 transition-all duration-300">
              看看我的训练 📸
            </a>
            <a href="https://strava.com" target="_blank" class="px-8 py-4 bg-white text-orange-500 border-2 border-orange-100 rounded-full font-bold hover:border-orange-500 hover:shadow-lg transition-all duration-300">
              查看 Strava 数据 📊
            </a>
          </div>
        </section>

        <!-- 2. Philosophy: 卡片式布局，圆角更大 -->
        <section id="philosophy" class="grid md:grid-cols-3 gap-6">
          {[
            { icon: "🧘", title: "心流状态", desc: "水下没有消息通知，只有呼吸和划水。这是我最专注的时刻。" },
            { icon: "💪", title: "自律即自由", desc: "无论冬夏，清晨 6 点的泳池见证了我的坚持。游泳教会我延迟满足。" },
            { icon: "🌊", title: "像水一样", desc: "遇到困难像水流绕过岩石。游泳不仅是运动，更是生活哲学。" }
          ].map((item) => (
            <div class="group p-8 bg-white/60 backdrop-blur-sm rounded-3xl border border-white/60 shadow-sm hover:shadow-xl hover:bg-white hover:-translate-y-2 transition-all duration-300">
              <div class="text-5xl mb-4 group-hover:scale-110 transition-transform duration-300">{item.icon}</div>
              <h3 class="text-xl font-bold text-slate-800 mb-3">{item.title}</h3>
              <p class="text-slate-600 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </section>

        <!-- 3. Gallery: 瀑布流风格 (模拟) -->
        <section id="gallery">
          <div class="flex items-center justify-between mb-8">
            <h2 class="text-3xl font-black text-slate-800">📸 比赛瞬间</h2>
            <span class="text-sm font-bold text-blue-600 bg-blue-100 px-3 py-1 rounded-full">精彩赛季</span>
          </div>
          
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 auto-rows-[200px]">
            <!-- 图片占位符：使用 Unsplash 的游泳关键词 -->
            <div class="col-span-2 row-span-2 relative group overflow-hidden rounded-3xl shadow-lg">
              <img src="/images/2025维港赛.png" alt="Swimming" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
                <p class="text-white font-bold text-lg">2025 香港维港赛</p>
              </div>
            </div>
            
            <div class="relative group overflow-hidden rounded-3xl shadow-lg">
              <img src="/images/自由泳移臂.png" alt="Goggles" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
            </div>
            
            <div class="relative group overflow-hidden rounded-3xl shadow-lg">
              <img src="/images/蛙泳伸手.png" alt="Pool Lane" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
            </div>

            <div class="col-span-2 relative group overflow-hidden rounded-3xl shadow-lg">
              <img src="/images/趣味水运会.jpg" alt="Training" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
               <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
                <p class="text-white font-bold text-lg">间歇训练后的力竭与快乐</p>
              </div>
            </div>
          </div>
        </section>


        <!-- 3. Gallery: 瀑布流风格 (模拟) -->
        <section id="gallery">
          <div class="flex items-center justify-between mb-8">
            <h2 class="text-3xl font-black text-slate-800">📸 公益讲座</h2>
            <span class="text-sm font-bold text-blue-600 bg-blue-100 px-3 py-1 rounded-full">深圳</span>
            <span class="text-sm font-bold text-blue-600 bg-blue-100 px-3 py-1 rounded-full">广州</span>
            <span class="text-sm font-bold text-blue-600 bg-blue-100 px-3 py-1 rounded-full">从化</span>
          </div>
          
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 auto-rows-[200px]">
            <!-- 图片占位符：使用 Unsplash 的游泳关键词 -->
            <div class="col-span-2 row-span-2 relative group overflow-hidden rounded-3xl shadow-lg">
              <img src="/images/知识讲座1.jpg" alt="Swimming" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
                <p class="text-white font-bold text-lg">2017 深圳图书馆.游泳公益讲座</p>
              </div>
            </div>
            
            <div class="relative group overflow-hidden rounded-3xl shadow-lg">
              <img src="/images/知识讲座2.jpg" alt="Goggles" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
            </div>
            
            <div class="relative group overflow-hidden rounded-3xl shadow-lg">
              <img src="/images/知识讲座3.jpg" alt="Pool Lane" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
            </div>

            <div class="col-span-2 relative group overflow-hidden rounded-3xl shadow-lg">
              <img src="/images/知识讲座4.jpg" alt="Training" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
               <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
                <p class="text-white font-bold text-lg">2016 广州图书馆.游泳公益讲座</p>
              </div>
            </div>
          </div>
        </section>




        
        <!-- 4. Gear: 活泼的列表 -->
        <section id="gear" class="bg-white/80 backdrop-blur-md rounded-[3rem] p-8 md:p-12 shadow-sm border border-white/60">
          <h2 class="text-3xl font-black text-slate-800 mb-8 text-center">🎒 我的装备库</h2>
          <div class="grid md:grid-cols-2 gap-8">
            <div class="space-y-4">
              <div class="flex items-center gap-4 p-4 rounded-2xl bg-blue-50 hover:bg-blue-100 transition-colors">
                <div class="text-3xl">👓</div>
                <div>
                  <h4 class="font-bold text-slate-800">Arena Cobra Ultra</h4>
                  <p class="text-sm text-slate-500">竞赛级泳镜，视野超清晰</p>
                </div>
              </div>
              <div class="flex items-center gap-4 p-4 rounded-2xl bg-orange-50 hover:bg-orange-100 transition-colors">
                <div class="text-3xl">🧢</div>
                <div>
                  <h4 class="font-bold text-slate-800">硅胶竞速泳帽</h4>
                  <p class="text-sm text-slate-500">减少阻力，保护头发</p>
                </div>
              </div>
            </div>
            <div class="space-y-4">
              <div class="flex items-center gap-4 p-4 rounded-2xl bg-cyan-50 hover:bg-cyan-100 transition-colors">
                <div class="text-3xl">⌚</div>
                <div>
                  <h4 class="font-bold text-slate-800">Garmin Swim 2</h4>
                  <p class="text-sm text-slate-500">精准记录 SWOLF 和配速</p>
                </div>
              </div>
              <div class="flex items-center gap-4 p-4 rounded-2xl bg-purple-50 hover:bg-purple-100 transition-colors">
                <div class="text-3xl">🦵</div>
                <div>
                  <h4 class="font-bold text-slate-800">短脚蹼</h4>
                  <p class="text-sm text-slate-500">打腿训练神器</p>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- 5. Footer / CTA -->
        <section class="text-center py-12">
          <h2 class="text-4xl font-black text-slate-800 mb-6">想一起下水吗？</h2>
          <p class="text-lg text-slate-600 mb-8">无论是约泳还是交流训练心得，都欢迎联系我！</p>
          <a href="mailto:your@email.com" class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-orange-400 to-pink-500 text-white rounded-full font-bold shadow-lg shadow-orange-400/40 hover:shadow-orange-400/60 hover:scale-105 transition-all duration-300">
            发送邮件 📩
          </a>
          
          <div class="mt-16 pt-8 border-t border-slate-200/60 flex flex-col md:flex-row justify-between items-center text-slate-500 text-sm">
            <p>© 2026 YourName's Swimming Log. Stay Wet! 💦</p>
            <a href="/" class="mt-4 md:mt-0 font-bold text-blue-600 hover:underline">&larr; 回到开发世界</a>
          </div>
        </section>

      </div>
    </main>
  </body>
</html>