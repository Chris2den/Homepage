---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="YourName | Creative Dev" description="Building fun, interactive, and beautiful web experiences.">
  
  <div class="max-w-5xl mx-auto px-6 space-y-32">

    <!-- 1. Hero Section: 大字号 + 动态渐变文字 -->
    <section class="relative min-h-[60vh] flex flex-col justify-center items-start">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 border border-white/20 backdrop-blur-md text-xs font-mono text-cyan-300 mb-6 fade-in-up">
        <span class="animate-pulse">👋</span> Hello, I'm Chris
      </div>
      
      <h1 class="text-6xl md:text-8xl font-extrabold text-white leading-[1.1] mb-8 fade-in-up delay-100">
        写代码，<br />
        也<span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 via-purple-500 to-cyan-500 animate-pulse">玩创意</span>。
      </h1>
      
      <p class="text-xl md:text-2xl text-slate-300 max-w-2xl leading-relaxed mb-10 fade-in-up delay-200">
        全栈开发 | 资深测试 | 游泳爱好者 <br>
        我不只构建功能，我创造<strong class="text-white">体验</strong>。
        喜欢把复杂的逻辑变成优雅的交互。
      </p>

      <div class="flex flex-wrap gap-4 fade-in-up delay-300">
        <!-- 磁吸按钮容器 -->
        <div class="group relative">
          <div class="absolute -inset-0.5 bg-gradient-to-r from-pink-600 to-purple-600 rounded-lg blur opacity-75 group-hover:opacity-100 transition duration-200"></div>
          <a href="#work" class="relative inline-flex items-center justify-center px-8 py-4 bg-slate-900 text-white rounded-lg font-bold leading-none transition-transform active:scale-95">
            看看我的作品
            <svg class="w-5 h-5 ml-2 -mr-1 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
        
        <a href="#contact" class="inline-flex items-center justify-center px-8 py-4 bg-white/10 hover:bg-white/20 backdrop-blur-md border border-white/20 text-white rounded-lg font-semibold transition-all hover:scale-105 active:scale-95">
          喝杯咖啡聊聊 ☕
        </a>
      </div>
    </section>

    <!-- 2. Tech Stack: 漂浮的标签云 -->
    <section>
      <h2 class="text-sm font-mono text-slate-400 mb-8 uppercase tracking-widest flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-cyan-400"></span> 武器库
      </h2>
      <div class="flex flex-wrap gap-3">
        {[
          "C#.NET", "JAVA", "Visual Basic", "C/C++", "Oracle", "SQL Server", "PostgreSQL", "MongoDB",
          "LoadRunner","QTP/UFT","Selenium+RF+Appium","JMeter","JUnit",
          "Postman","Git","Jenkins", "JIRE","Bugzilla","WIN CVS"

        ].map((tech, i) => (
          <span 
            key={tech}
            
            class="px-3 py-1 rounded-lg bg-white/5 border border-white/10 text-xs text-slate-300 font-medium hover:bg-white/10 hover:border-cyan-500/50 hover:text-cyan-300 hover:-translate-y-1 hover:shadow-[0_0_20px_rgba(34,211,238,0.3)] transition-all duration-300 cursor-default select-none"
            style={`animation-delay: ${i * 50}ms`}
          >
            {tech}
          </span>
        ))}
      </div>
    </section>

    <!-- 3. Selected Work: 玻璃卡片 + 悬停光效 -->
    <section id="work">
      <h2 class="text-4xl font-bold text-white mb-12 fade-in-up">精选项目</h2>
      <div class="grid md:grid-cols-2 gap-8">
        


<!-- 项目卡片 1 -->
{/* 1. 将外层 div 换成 a 标签，并加上 block 样式 */}
<a href="https://app.chris2den.me/" target="_blank" rel="noopener" class="group relative p-1 rounded-3xl bg-gradient-to-b from-white/10 to-white/5 hover:from-pink-500/50 hover:to-purple-500/50 transition-all duration-500">
  <article class="relative h-full"> {/* 内部包裹一层保持结构 */}
    <div class="relative h-64 overflow-hidden rounded-[22px] bg-slate-900">
      <div class="absolute inset-0 bg-slate-800 flex items-center justify-center text-slate-600 group-hover:scale-110 transition-transform duration-700">
        <img src="/images/p1.jpg"/>
      </div>
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-transparent to-transparent opacity-80"></div>
    </div>
    <div class="p-8 relative">
      <h3 class="text-2xl font-bold text-white mb-2 group-hover:text-cyan-300 transition-colors">平安好车主APP</h3>
      <p class="text-slate-400 mb-4 line-clamp-2">
        平安产险主推APP，主要包括车生活及车险投保。推荐理由：加油有折扣。
        前世今生：早期为平安科技车主商场项目（Web/H5），围绕车生活，签约全国4s店/维修厂以及礼品发放（积分商城）。
        因主要会员为车险用户移交给平安产险管理，后经过多次系统重构。
        我是初创团队测试Leader，第一二次重构的SA/测试Leader/敏捷教练。
      </p>
      <div class="flex gap-2 text-xs font-mono text-cyan-300">
        <span>#测试Leader</span><span>#系统分析师</span>
      </div>
    </div>
  </article>
</a>


<!-- 项目卡片 2 -->
{/* 1. 将外层 div 换成 a 标签，并加上 block 样式 */}
<a href="https://app.chris2den.me/" target="_blank" rel="noopener" class="group relative block p-1 rounded-3xl bg-gradient-to-b from-white/10 to-white/5 hover:from-cyan-500/50 hover:to-blue-500/50 transition-all duration-500">
  <article class="relative h-full"> {/* 内部包裹一层保持结构 */}
    <div class="relative h-64 overflow-hidden rounded-[22px] bg-slate-900">
      <div class="absolute inset-0 bg-slate-800 flex items-center justify-center text-slate-600 group-hover:scale-110 transition-transform duration-700">
        <img src="/images/p2.jpg"/>
      </div>
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-transparent to-transparent opacity-80"></div>
    </div>
    <div class="p-8 relative">
      <h3 class="text-2xl font-bold text-white mb-2 group-hover:text-cyan-300 transition-colors">星易选码XY</h3>
      <p class="text-slate-400 mb-4 line-clamp-2">一个精致酷炫的彩球游戏。我们可以私人定制；如果您有好的想法，期盼合作，共创价值。</p>
      <div class="flex gap-2 text-xs font-mono text-purple-300">
        <span>#独立开发者</span>
      </div>
    </div>
  </article>
</a>

<!-- 项目卡片 3 -->
{/* 1. 将外层 div 换成 a 标签，并加上 block 样式 */}
<a href="http://epub.cnipa.gov.cn/patent/CN112069068B" target="_blank" rel="noopener" class="group relative block p-1 rounded-3xl bg-gradient-to-b from-white/10 to-white/5 hover:from-cyan-500/50 hover:to-blue-500/50 transition-all duration-500">
  <article class="relative h-full"> {/* 内部包裹一层保持结构 */}
    <div class="relative h-64 overflow-hidden rounded-[22px] bg-slate-900">
      <div class="absolute inset-0 bg-slate-800 flex items-center justify-center text-slate-600 group-hover:scale-110 transition-transform duration-700">
        <img src="/images/p3.jpg"/>
      </div>
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-transparent to-transparent opacity-80"></div>
    </div>
    <div class="p-8 relative">
      <h3 class="text-2xl font-bold text-white mb-2 group-hover:text-cyan-300 transition-colors">自动化测试发明专利</h3>
      <p class="text-slate-400 mb-4 line-clamp-2">
        是自动化框架，更是自动化实施的观察和理解。
        它与coding同出一源，又有独特属性。合理规划、高效产出和低成本维护是项目成败的关键。  
      </p>
      <div class="flex gap-2 text-xs font-mono text-purple-300">
        <span>#专利发明人</span>
      </div>
    </div>
  </article>
</a>


        <!-- 项目卡片 4 -->
        <article class="group relative p-1 rounded-3xl bg-gradient-to-b from-white/10 to-white/5 hover:from-pink-500/50 hover:to-purple-500/50 transition-all duration-500">
          <div class="relative h-64 overflow-hidden rounded-[22px] bg-slate-900">
             <!-- 模拟截图，实际可换 img -->
             <div class="absolute inset-0 bg-slate-800 flex items-center justify-center text-slate-600 group-hover:scale-110 transition-transform duration-700">
                
              <img src="/images/p4.jpg"/>

             </div>
             <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-transparent to-transparent opacity-80"></div>
          </div>
          <div class="p-8 relative">
            <div class="absolute -top-10 right-8 p-3 bg-slate-900/80 backdrop-blur-md rounded-2xl border border-white/10 shadow-xl opacity-0 group-hover:opacity-100 group-hover:-translate-y-2 transition-all duration-300">
              <a href="#" class="text-white hover:text-pink-400"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg></a>
            </div>
            <h3 class="text-2xl font-bold text-white mb-2 group-hover:text-pink-300 transition-colors">质量与效率 Scrum</h3>
            <p class="text-slate-400 mb-4 line-clamp-2">
        效率是竞争力核心，质量是核心竞争力基础。遵循敏捷Scrum把产品需求、研发和测试等三大环节，
        高效有序的融合。追求产品零缺陷，高效价值交付，获得用户认同。  
            </p>
            <div class="flex gap-2 text-xs font-mono text-cyan-300">
              <span>#敏捷教练</span><span>#测试专家</span>
            </div>
          </div>
        </article>

      </div>
    </section>

    <!-- 4. Playground / Ideas: 轻松的个人角落 -->
    <section id="playground" class="relative p-8 md:p-12 rounded-3xl bg-white/5 border border-white/10 backdrop-blur-sm overflow-hidden">
      <!-- 装饰背景字 -->
      <div class="absolute -right-10 -top-10 text-[200px] font-bold text-white/5 select-none pointer-events-none rotate-12"> Chris </div>
      
      <h2 class="text-3xl font-bold text-white mb-6 relative z-10">🧪 实验与思考</h2>
      <div class="grid md:grid-cols-3 gap-6 relative z-10">
        <div class="p-6 rounded-2xl bg-slate-900/50 border border-white/5 hover:bg-slate-800/50 transition-colors">
          <div class="text-3xl mb-3">☕</div>
          <h3 class="font-bold text-white mb-2">Vibe Coding --</h3>
          <p class="text-sm text-slate-400">
先说结论：我认为现阶段Vibe Coding过于浪漫，做减法之前并不适合大项目。
未来AI不是模仿/代替人类编程，而是提供一种全新的编程范式，强调人机协同和代码的可演化性。
即“面向AI编程”，可概括为1框2可3原则：
人机可协同框架；可原型推演/可局部进化；编码颗粒化原则/修改局部化原则/代码双语化原则。
欢迎加入讨论...
          </p>
        </div>
        <div class="p-6 rounded-2xl bg-slate-900/50 border border-white/5 hover:bg-slate-800/50 transition-colors">
          <div class="text-3xl mb-3">🎵</div>
          <h3 class="font-bold text-white mb-2">生成式音乐ing</h3>
          <p class="text-sm text-slate-400">尝试用 Web Audio API 编写一段根据天气变化的背景音乐。</p>
        </div>
        <div class="p-6 rounded-2xl bg-slate-900/50 border border-white/5 hover:bg-slate-800/50 transition-colors">
          <div class="text-3xl mb-3">🏊‍♂️</div>
          <h3 class="font-bold text-white mb-2">数字游民生活</h3>
          <p class="text-sm text-slate-400">如何在保持高效开发的同时，享受泳池边的下午时光？</p>
        </div>
      </div>
    </section>

    <!-- 5. Contact: 大气的结尾 -->
    <section id="contact" class="text-center py-20">
      <h2 class="text-5xl md:text-7xl font-bold text-white mb-8 tracking-tight">
        有个好点子？<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-pink-400">让我们把它实现。</span>
      </h2>
      <p class="text-xl text-slate-400 mb-10 max-w-2xl mx-auto">
        无论是全职机会、自由合作项目，还是只是想聊聊游泳和技术，我都欢迎。
      </p>
      <a href="mailto:chris2den@126.com" class="inline-block px-10 py-5 bg-white text-slate-950 rounded-full font-bold text-lg hover:scale-110 hover:shadow-[0_0_40px_rgba(255,255,255,0.4)] transition-all duration-300">
        发送邮件给我 ✉️
      </a>
    </section>

  </div>
  
  <!-- 简单的脚本：让元素在滚动时淡入 -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('fade-in-up');
            // 移除延迟类以确保动画立即执行（如果需要）
            // entry.target.style.animationDelay = '0s'; 
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('section > *').forEach((el) => {
        // 给没有 fade-in-up 的元素加上初始状态，以便观察器触发
        if(!el.classList.contains('fade-in-up')) {
           el.style.opacity = '0';
           el.style.transform = 'translateY(20px)';
           // 这里简化处理，实际项目中建议直接在 CSS 定义默认状态
        }
        observer.observe(el);
      });
    });
  </script>
</Layout>